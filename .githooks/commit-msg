#!/usr/bin/env bash
# Validates that commit messages follow Conventional Commits format.
# https://www.conventionalcommits.org/
#
# Allowed types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits and fixup commits.
if echo "$COMMIT_MSG" | grep -qE "^(Merge |fixup! |squash! )"; then
  exit 0
fi

PATTERN="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?(!)?: .{1,100}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Invalid commit message format"
  echo ""
  echo "  Expected: <type>(<scope>): <description>"
  echo "  Example:  feat(cli): add profile filtering"
  echo ""
  echo "  Allowed types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
  echo ""
  echo "  See: https://www.conventionalcommits.org/"
  echo ""
  exit 1
fi
