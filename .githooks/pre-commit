#!/usr/bin/env bash
# aiswitch pre-commit hook
# Activated by: make hooks
# Checks: gofmt, go vet, golangci-lint

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
warn() { echo -e "  ${YELLOW}!${RESET} $1"; }
info() { echo -e "  ${BOLD}▸${RESET} $1"; }

echo ""
echo -e "${BOLD}aiswitch pre-commit${RESET}"
echo "──────────────────────────────────────"

ERRORS=0

# ── 1. gofmt ────────────────────────────────────────────────────────────────
info "gofmt"
UNFORMATTED=$(gofmt -l . 2>/dev/null)
if [ -n "$UNFORMATTED" ]; then
  fail "files not properly formatted:"
  echo "$UNFORMATTED" | sed 's/^/      /'
  echo ""
  echo -e "      Run ${BOLD}gofmt -w .${RESET} to fix"
  ERRORS=$((ERRORS + 1))
else
  pass "gofmt"
fi

# ── 2. go vet ───────────────────────────────────────────────────────────────
info "go vet"
if ! go vet ./... 2>&1; then
  fail "go vet"
  ERRORS=$((ERRORS + 1))
else
  pass "go vet"
fi

# ── 3. go build ─────────────────────────────────────────────────────────────
info "go build"
if ! go build -buildvcs=false ./... 2>&1; then
  fail "go build"
  ERRORS=$((ERRORS + 1))
else
  pass "go build"
fi

# ── 4. golangci-lint ────────────────────────────────────────────────────────
info "golangci-lint"
if command -v golangci-lint &>/dev/null; then
  if ! golangci-lint run --timeout=5m 2>&1; then
    fail "golangci-lint"
    ERRORS=$((ERRORS + 1))
  else
    pass "golangci-lint"
  fi
else
  warn "golangci-lint not found — skipping"
  warn "Install: https://golangci-lint.run/usage/install/"
fi

echo "──────────────────────────────────────"

if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}${BOLD}Commit blocked — $ERRORS check(s) failed${RESET}"
  echo ""
  echo -e "  Fix the issues above, then ${BOLD}git add${RESET} and try again."
  echo -e "  To skip (not recommended): ${BOLD}git commit --no-verify${RESET}"
  echo ""
  exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — committing${RESET}"
echo ""
