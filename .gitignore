# ── Compiled binaries ─────────────────────────────────────────────────────────
# Local build output directories
bin/
dist/

# Root-level binary produced by `go build .`
/aiswitch
/aiswitch.exe

# Any cross-compiled output patterns (e.g. aiswitch-darwin-arm64)
/aiswitch-*

# Windows executables anywhere in the tree
*.exe

# GoReleaser artifacts
/dist/

# ── Go toolchain ───────────────────────────────────────────────────────────────
*.test
*.out
vendor/

# ── OS & editor artefacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

.idea/
*.iml
.vscode/
*.code-workspace

*.swp
*.swo
*~

# ── Environment / secrets (never commit these) ────────────────────────────────
.env
.env.*
*.pem
*.key

# ── aiswitch runtime files (never commit these) ───────────────────────────────
# User data — belongs in ~/.aiswitch/, not in any repo
.aiswitch/env.sh
.aiswitch/env.ps1
.aiswitch/config.json
.aiswitch/secrets.json
